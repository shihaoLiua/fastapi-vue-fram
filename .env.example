# Application
APP_NAME=FastAPI Vue Scaffold
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/fastapi_vue

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:80","http://localhost"]

# Superuser (auto-created on first startup)
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123
FIRST_SUPERUSER_USERNAME=admin
